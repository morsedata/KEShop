<div class="ks-section color-scheme-1">
  <div class="ks-wrap">
    <div class="ks-section-head ks-reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="ks-eyebrow ks-center">{{ section.settings.eyebrow }}</div>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    </div>

    <div class="ks-collections">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="ks-coll-card ks-reveal" {{ block.shopify_attributes }}>
          <div class="ks-coll-media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              <svg viewBox="0 0 100 100" fill="none" stroke-width="1.6"><path d="M35 20 L35 55 Q35 78 50 82 Q65 78 65 55 L65 20"/><line x1="35" y1="34" x2="65" y2="34"/></svg>
            {%- endif -%}
          </div>
          <div class="ks-coll-body">
            <div class="ks-tag">{{ block.settings.tag }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
            <div class="ks-link">
              {{ block.settings.link_label }}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Kingsdale Collections",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Portfolio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three Houses, One Standard" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From the sock that started it all to gifting your clients will actually keep — every line carries the same finish." }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (optional — falls back to a line icon)" },
        { "type": "text", "id": "tag", "label": "Drawer label", "default": "Drawer One" },
        { "type": "text", "id": "title", "label": "Title", "default": "Signature Socks" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Bold colourways and premium yarns — the collection Kingsdale was built on." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop the Signature Line" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kingsdale Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "tag": "Drawer One", "title": "Signature Socks", "description": "Bold colourways and premium yarns — the collection Kingsdale was built on.", "link_label": "Shop the Signature Line" } },
        { "type": "collection_card", "settings": { "tag": "Drawer Two", "title": "Custom Apparel", "description": "A curated portfolio of lifestyle pieces, made to the same exacting standard.", "link_label": "View Lifestyle Apparel" } },
        { "type": "collection_card", "settings": { "tag": "Drawer Three", "title": "Corporate Gifting", "description": "Branded socks for events, onboarding and clients who deserve better swag.", "link_label": "Start a Gifting Order" } }
      ]
    }
  ]
}
{% endschema %}
