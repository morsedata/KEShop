{%- comment -%}
  Floating WhatsApp bubble, gold outline per brand spec.
  Phone number and default message are theme settings so a merchant can
  update them from Theme Settings without touching code.
{%- endcomment -%}
{%- if settings.ks_whatsapp_number != blank -%}
  {%- assign ks_wa_digits = settings.ks_whatsapp_number | remove: '+' | remove: ' ' | remove: '-' -%}
  <a
    href="https://wa.me/{{ ks_wa_digits }}?text={{ settings.ks_whatsapp_default_message | default: 'Hello Kingsdale Emporio! I have a question.' | url_encode }}"
    target="_blank"
    rel="noopener"
    class="ks-wa-float"
    aria-label="Chat with us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6">
      <path d="M3 21l1.65-4.95A9 9 0 1 1 8 20.35z"/>
      <path d="M8.5 8.5c0 4 3.5 7.5 7.5 7.5.6 0 1-.4 1-1v-1.4a1 1 0 0 0-.7-1L14 12l-1 1.5a6 6 0 0 1-3.5-3.5L11 9l-.6-2.3a1 1 0 0 0-1-.7H8c-.6 0-1 .4-1 1 0 .2 0 .3.5 1.5z"/>
    </svg>
  </a>
{%- endif -%}
