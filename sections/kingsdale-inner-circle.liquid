<div class="ks-section color-scheme-1" id="circle">
  <div class="ks-wrap">
    <div class="ks-inner-circle ks-reveal">
      <div class="ks-eyebrow ks-center">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      <form name="submit-to-google-sheet-{{ section.id }}" id="ks-ic-form-{{ section.id }}" class="ks-ic-form">
        <input type="email" name="Email" placeholder="Enter your email address" required aria-label="Email address">
        <button type="submit" id="ks-submit-btn-{{ section.id }}">Subscribe</button>
      </form>
    </div>
  </div>
</div>

<div class="ks-modal" id="ks-success-modal-{{ section.id }}">
  <div class="ks-modal-panel">
    <button class="ks-modal-close" id="ks-close-modal-{{ section.id }}" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>
    </button>
    <div class="ks-eyebrow ks-center">Welcome</div>
    <h3>{{ section.settings.modal_heading }}</h3>
    <p>{{ section.settings.modal_body }}</p>
  </div>
</div>

{%- if section.settings.script_url != blank -%}
<script>
  (function () {
    var scriptURL = {{ section.settings.script_url | json }};
    var form = document.forms['submit-to-google-sheet-{{ section.id }}'];
    var submitBtn = document.getElementById('ks-submit-btn-{{ section.id }}');
    var modal = document.getElementById('ks-success-modal-{{ section.id }}');
    var closeModalBtn = document.getElementById('ks-close-modal-{{ section.id }}');

    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var originalBtnText = submitBtn.textContent;
      submitBtn.textContent = 'Curating...';
      submitBtn.style.opacity = '0.7';
      submitBtn.disabled = true;

      fetch(scriptURL, { method: 'POST', body: new FormData(form) })
        .then(function () {
          modal.classList.add('active');
          form.reset();
          submitBtn.textContent = originalBtnText;
          submitBtn.style.opacity = '1';
          submitBtn.disabled = false;
        })
        .catch(function (error) {
          console.error('Error!', error.message);
          alert('There was an error connecting to our servers. Please try again.');
          submitBtn.textContent = originalBtnText;
          submitBtn.style.opacity = '1';
          submitBtn.disabled = false;
        });
    });

    closeModalBtn.addEventListener('click', function () {
      modal.classList.remove('active');
    });

    window.addEventListener('click', function (e) {
      if (e.target === modal) modal.classList.remove('active');
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Kingsdale Inner Circle",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Welcome to the" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Inner Circle" },
    { "type": "textarea", "id": "body", "label": "Body copy", "default": "Exclusive offers, early access to new colourways, and first word on limited corporate-gifting slots — straight to your inbox." },
    {
      "type": "text",
      "id": "script_url",
      "label": "Google Apps Script URL",
      "default": "https://script.google.com/macros/s/AKfycbxC-fDnWNscNvxUYs6nIsivbDNpKyM7Spzhr6vIbKsUpL7Ct9jnSytcO7aJY3uq7s3i/exec",
      "info": "The subscribe form posts here. Swap this for a Klaviyo/Omnisend endpoint later without touching code."
    },
    { "type": "text", "id": "modal_heading", "label": "Success modal heading", "default": "You're in the Inner Circle" },
    { "type": "textarea", "id": "modal_body", "label": "Success modal body", "default": "Thank you for subscribing. Expect early access to new colourways and first word on limited corporate-gifting slots, straight to your inbox." }
  ],
  "presets": [
    { "name": "Kingsdale Inner Circle" }
  ]
}
{% endschema %}
