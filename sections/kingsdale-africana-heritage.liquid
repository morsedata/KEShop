{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- if section.settings.quick_add == 'bulk' -%}
    {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
  {%- else -%}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endunless -%}

<div class="ks-section color-scheme-2">
  <div class="ks-wrap">
    <div class="ks-section-head ks-reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="ks-eyebrow ks-center">{{ section.settings.eyebrow }}</div>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
      <div class="ks-swatch-row" aria-hidden="true">
        <span class="ks-swatch" style="background: rgb(var(--ks-heritage-red)); color: rgb(var(--ks-heritage-red));"></span>
        <span class="ks-swatch" style="background: rgb(var(--ks-ochre)); color: rgb(var(--ks-ochre));"></span>
        <span class="ks-swatch" style="background: rgb(var(--ks-cerulean)); color: rgb(var(--ks-cerulean));"></span>
        <span class="ks-swatch" style="background: rgb(var(--ks-emerald-rgb)); color: rgb(var(--ks-emerald-rgb));"></span>
      </div>
    </div>

    {%- comment -%}
      Real product data: pulls from whichever Shopify collection the merchant
      selects in the theme editor, rendered with Dawn's own card-product
      snippet so pricing, variants, quick-add and the cart all work natively.
      The colour tag cycles through the four Africana Heritage accent colours
      purely as a decorative label — it reads section.settings.color_tag_1-4
      in rotation, or falls back to product tags matching "red"/"ochre" etc.
      if you tag products that way in the admin.
    {%- endcomment -%}
    {%- assign ks_collection = collections[section.settings.collection] -%}
    {%- assign ks_colors = 'red,ochre,blue,green' | split: ',' -%}

    {%- if ks_collection != blank and ks_collection.products.size > 0 -%}
      <div class="ks-africana-grid">
        {%- for product in ks_collection.products limit: section.settings.products_to_show -%}
          {%- assign ks_color_index = forloop.index0 | modulo: 4 -%}
          {%- assign ks_color = ks_colors[ks_color_index] -%}
          <div class="ks-reveal">
            <div class="ks-a-tag {{ ks_color }}">
              {%- case ks_color -%}
                {%- when 'red' -%}Heritage Red
                {%- when 'ochre' -%}Vibrant Ochre
                {%- when 'blue' -%}Cerulean Blue
                {%- when 'green' -%}Emerald Green
              {%- endcase -%}
            </div>
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'square',
              show_vendor: false,
              show_rating: false,
              quick_add: section.settings.quick_add,
              section_id: section.id,
              product_view_context: 'collection'
            %}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="ks-reveal" style="text-align:center; color: rgba(var(--color-foreground), 0.6);">
        Select a collection in the theme editor to populate the Africana Heritage grid.
      </p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Kingsdale Africana Heritage",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Visual Tension" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Africana Heritage Collection" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "The house is black and gold — strict, regal, quiet. What it holds is not. Heritage Red, Vibrant Ochre, Cerulean Blue, Emerald Green: four colourways, one philosophy." },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Choose the real Shopify collection to display here." },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    {
      "type": "select",
      "id": "quick_add",
      "label": "Quick add",
      "default": "standard",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "standard", "label": "Standard" },
        { "value": "bulk", "label": "Bulk" }
      ]
    }
  ],
  "presets": [
    { "name": "Kingsdale Africana Heritage" }
  ]
}
{% endschema %}
